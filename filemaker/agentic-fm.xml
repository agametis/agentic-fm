          </Title>
          <Message>
            <Calculation><![CDATA["Companion server not running. Start it with:¶¶python3 agent/scripts/companion_server.py"]]></Calculation>
          </Message>
          <Buttons>
            <Button CommitState="False">
              <Calculation><![CDATA["OK"]]></Calculation>
            </Button>
            <Button CommitState="False"/>
            <Button CommitState="False"/>
          </Buttons>
        </Step>
        <Step enable="True" id="70" name="End If"/>
        <Step enable="True" id="89" name="# (comment)"/>
        <Step enable="True" id="103" name="Exit Script"/>
        <Step enable="True" id="89" name="# (comment)"/>
        <Step enable="True" id="89" name="# (comment)">
          <Text>Example of how to call Agentic-fm Debug</Text>
        </Step>
        <Step enable="False" id="1" name="Perform Script">
          <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "label" ; "after Insert from URL" ; JSONString ] ;
	[ "vars"  ; JSONSetElement ( "{}" ;
		[ "exitCode"  ; $exitCode  ; JSONString ] ;
		[ "httpError" ; $httpError ; JSONString ] ;
		[ "response"  ; $response  ; JSONString ]
	) ; JSONRaw ]
)]]></Calculation>
          <Script id="10" name="Agentic-fm Debug"/>
        </Step>
      </Script>
