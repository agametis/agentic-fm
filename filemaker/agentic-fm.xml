<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Group groupCollapsed="False" includeInMenu="False" id="1" name="agentic-fm">
    <Script includeInMenu="False" SiriShortcutVisible="False" runFullAccess="False" id="2" name="Get agentic-fm path">
      <Step enable="True" id="89" name="# (comment)">
        <Text>PURPOSE: Set a global variable used by other scripts to key/value pairs used by agentic-fm.</Text>
      </Step>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="141" name="Set Variable">
        <Value>
          <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "path" ; "" ; JSONString ]
)]]></Calculation>
        </Value>
        <Repetition>
          <Calculation><![CDATA[1]]></Calculation>
        </Repetition>
        <Name>$config_example</Name>
      </Step>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="68" name="If">
        <Restore state="False"/>
        <Calculation><![CDATA[IsEmpty ( $$AGENTIC.FM ) or JSONGetElementType ( $$AGENTIC.FM ; "" ) ≠ JSONObject]]></Calculation>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Repetition>
          <Calculation><![CDATA[1]]></Calculation>
        </Repetition>
        <Name>$path</Name>
      </Step>
      <Step enable="True" id="181" name="Get Folder Path">
        <AllowFolderCreation state="False"/>
        <Repetition>
          <Calculation><![CDATA[1]]></Calculation>
        </Repetition>
        <DialogTitle>
          <Calculation><![CDATA["Select the agentic-fm folder"]]></Calculation>
        </DialogTitle>
        <DefaultLocation>
          <Calculation><![CDATA[Get ( DesktopPath )]]></Calculation>
        </DefaultLocation>
        <Name>$path</Name>
      </Step>
      <Step enable="True" id="69" name="Else">
        <Restore state="False"/>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Value>
          <Calculation><![CDATA[JSONGetElement ( $$AGENTIC.FM ; "path" )]]></Calculation>
        </Value>
        <Repetition>
          <Calculation><![CDATA[1]]></Calculation>
        </Repetition>
        <Name>$path</Name>
      </Step>
      <Step enable="True" id="70" name="End If"/>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="89" name="# (comment)">
        <Text>Validate path</Text>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Value>
          <Calculation><![CDATA[$path & "fmparse.sh"]]></Calculation>
        </Value>
        <Repetition>
          <Calculation><![CDATA[1]]></Calculation>
        </Repetition>
        <Name>$fmparse</Name>
      </Step>
      <Step enable="True" id="188" name="Get File Exists">
        <UniversalPathList>$fmparse</UniversalPathList>
        <Text/>
        <Field>$exists</Field>
      </Step>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="68" name="If">
        <Restore state="False"/>
        <Calculation><![CDATA[not $exists]]></Calculation>
      </Step>
      <Step enable="True" id="87" name="Show Custom Dialog">
        <Title>
          <Calculation><![CDATA["Invalid folder path"]]></Calculation>
        </Title>
        <Message>
          <Calculation><![CDATA["Please clear the $$AGENTIC.FM global variable and run the script again to select the agentic-fm folder."]]></Calculation>
        </Message>
        <Buttons>
          <Button CommitState="True">
            <Calculation><![CDATA["OK"]]></Calculation>
          </Button>
          <Button CommitState="False"/>
          <Button CommitState="False"/>
        </Buttons>
      </Step>
      <Step enable="True" id="103" name="Exit Script">
        <Calculation><![CDATA[False]]></Calculation>
      </Step>
      <Step enable="True" id="70" name="End If"/>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="141" name="Set Variable">
        <Value>
          <Calculation><![CDATA[JSONSetElement ( If ( IsEmpty ( $$AGENTIC.FM ) ; "{}" ; $$AGENTIC.FM ) ;
	[ "path" ; $path ; JSONString ]
)]]></Calculation>
        </Value>
        <Repetition>
          <Calculation><![CDATA[1]]></Calculation>
        </Repetition>
        <Name>$$AGENTIC.FM</Name>
      </Step>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="103" name="Exit Script">
        <Calculation><![CDATA[True]]></Calculation>
      </Step>
    </Script>
    <Script includeInMenu="False" SiriShortcutVisible="False" runFullAccess="False" id="3" name="Explode XML">
      <Step enable="True" id="89" name="# (comment)">
        <Text>PURPOSE: Push out solution XML to be parsed for AI use.</Text>
      </Step>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="89" name="# (comment)">
        <Text>DEPENDENCY: The companion server must be running (agent/scripts/companion_server.py)</Text>
      </Step>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="1" name="Perform Script">
        <Script id="2" name="Get agentic-fm path"/>
      </Step>
      <Step enable="True" id="68" name="If">
        <Restore state="False"/>
        <Calculation><![CDATA[not Get ( ScriptResult )]]></Calculation>
      </Step>
      <Step enable="True" id="87" name="Show Custom Dialog">
        <Title>
          <Calculation><![CDATA["Bad install"]]></Calculation>
        </Title>
        <Message>
          <Calculation><![CDATA["The agentic-fm install was not found. Please check the $$AGENTIC.FM global variable"]]></Calculation>
        </Message>
        <Buttons>
          <Button CommitState="True">
            <Calculation><![CDATA["OK"]]></Calculation>
          </Button>
          <Button CommitState="False"/>
          <Button CommitState="False"/>
        </Buttons>
      </Step>
      <Step enable="True" id="103" name="Exit Script"/>
      <Step enable="True" id="70" name="End If"/>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="141" name="Set Variable">
        <Value>
          <Calculation><![CDATA[Get ( DesktopPath ) & Get ( FileName ) & ".xml"]]></Calculation>
        </Value>
        <Repetition>
          <Calculation><![CDATA[1]]></Calculation>
        </Repetition>
        <Name>$output</Name>
      </Step>
      <Step enable="True" id="3" name="Save a Copy as XML">
        <Option state="False"/>
        <UniversalPathList>$output</UniversalPathList>
        <Calculation><![CDATA[Get ( WindowName )]]></Calculation>
      </Step>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="141" name="Set Variable">
        <Value>
          <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "solution_name"     ; Get ( FileName )                                                              ; JSONString ] ;
	[ "export_file_path"  ; ConvertFromFileMakerPath ( $output ; 1 )                                      ; JSONString ] ;
	[ "repo_path"         ; ConvertFromFileMakerPath ( JSONGetElement ( $$AGENTIC.FM ; "path" ) ; 1 )     ; JSONString ] ;
	[ "exploder_bin_path" ; "~/bin/fm-xml-export-exploder"                                                ; JSONString ]
)]]></Calculation>
        </Value>
        <Repetition>
          <Calculation><![CDATA[1]]></Calculation>
        </Repetition>
        <Name>$payload</Name>
      </Step>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="160" name="Insert from URL">
        <NoInteract state="True"/>
        <DontEncodeURL state="False"/>
        <SelectAll state="True"/>
        <VerifySSLCertificates state="False"/>
        <CURLOptions>
          <Calculation><![CDATA["-X POST -H \"Content-Type: application/json\" -d " & Quote ( $payload )]]></Calculation>
        </CURLOptions>
        <Calculation><![CDATA["http://localhost:8765/explode"]]></Calculation>
        <Text/>
        <Field>$response</Field>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Value>
          <Calculation><![CDATA[Get ( LastError )]]></Calculation>
        </Value>
        <Repetition>
          <Calculation><![CDATA[1]]></Calculation>
        </Repetition>
        <Name>$httpError</Name>
      </Step>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="68" name="If">
        <Restore state="False"/>
        <Calculation><![CDATA[$httpError ≠ 0]]></Calculation>
      </Step>
      <Step enable="True" id="87" name="Show Custom Dialog">
        <Title>
          <Calculation><![CDATA["Companion server not running"]]></Calculation>
        </Title>
        <Message>
          <Calculation><![CDATA["Start the companion server first:¶¶python3 agent/scripts/companion_server.py¶¶Then run Explode XML again."]]></Calculation>
        </Message>
        <Buttons>
          <Button CommitState="True">
            <Calculation><![CDATA["OK"]]></Calculation>
          </Button>
          <Button CommitState="False"/>
          <Button CommitState="False"/>
        </Buttons>
      </Step>
      <Step enable="True" id="103" name="Exit Script"/>
      <Step enable="True" id="70" name="End If"/>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="141" name="Set Variable">
        <Value>
          <Calculation><![CDATA[JSONGetElement ( $response ; "success" )]]></Calculation>
        </Value>
        <Repetition>
          <Calculation><![CDATA[1]]></Calculation>
        </Repetition>
        <Name>$success</Name>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Value>
          <Calculation><![CDATA[JSONGetElement ( $response ; "stdout" )]]></Calculation>
        </Value>
        <Repetition>
          <Calculation><![CDATA[1]]></Calculation>
        </Repetition>
        <Name>$stdout</Name>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Value>
          <Calculation><![CDATA[JSONGetElement ( $response ; "stderr" )]]></Calculation>
        </Value>
        <Repetition>
          <Calculation><![CDATA[1]]></Calculation>
        </Repetition>
        <Name>$stderr</Name>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Value>
          <Calculation><![CDATA[JSONGetElement ( $response ; "exit_code" )]]></Calculation>
        </Value>
        <Repetition>
          <Calculation><![CDATA[1]]></Calculation>
        </Repetition>
        <Name>$exitCode</Name>
      </Step>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="68" name="If">
        <Restore state="False"/>
        <Calculation><![CDATA[not $success or $exitCode ≠ 0]]></Calculation>
      </Step>
      <Step enable="True" id="87" name="Show Custom Dialog">
        <Title>
          <Calculation><![CDATA["Error"]]></Calculation>
        </Title>
        <Message>
          <Calculation><![CDATA[$stderr & If ( not IsEmpty ( $stdout ) ; ¶ & $stdout ; "" )]]></Calculation>
        </Message>
        <Buttons>
          <Button CommitState="True">
            <Calculation><![CDATA["OK"]]></Calculation>
          </Button>
          <Button CommitState="False"/>
          <Button CommitState="False"/>
        </Buttons>
      </Step>
      <Step enable="True" id="69" name="Else">
        <Restore state="False"/>
      </Step>
      <Step enable="True" id="87" name="Show Custom Dialog">
        <Title>
          <Calculation><![CDATA["Finished"]]></Calculation>
        </Title>
        <Message>
          <Calculation><![CDATA["The XML has been placed into agentic-fm's xml_parsed folder." & If ( not IsEmpty ( $stdout ) ; "¶¶" & $stdout ; "" )]]></Calculation>
        </Message>
        <Buttons>
          <Button CommitState="True">
            <Calculation><![CDATA["OK"]]></Calculation>
          </Button>
          <Button CommitState="False"/>
          <Button CommitState="False"/>
        </Buttons>
      </Step>
      <Step enable="True" id="70" name="End If"/>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="103" name="Exit Script"/>
      <Step enable="True" id="89" name="# (comment)"/>
      <Step enable="True" id="89" name="# (comment)"/>
    </Script>
